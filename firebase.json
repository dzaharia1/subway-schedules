{
  "functions": {
    "source": ".",
    "ignore": [
      "node_modules",
      ".git",
      ".github",
      "feedfiles.zip",
      "output.log",
      ".env",
      ".env.local",
      "setup-log.json"
    ]
  },
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "function": "api"
      }
    ]
  }
}
